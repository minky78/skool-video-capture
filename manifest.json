{
  "manifest_version": 3,
  "name": "Skool Video Capture",
  "version": "3.0.0",
  "description": "Capture and download video streams from Skool.com — per-platform detection, quality selection, download manager.",
  "homepage_url": "https://github.com/minky78/skool-video-capture",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "webRequest",
    "activeTab",
    "storage",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.skool.com/*",
    "https://*.loom.com/*",
    "https://*.vimeo.com/*",
    "https://*.vimeocdn.com/*",
    "https://*.wistia.com/*",
    "https://*.wistia.net/*",
    "https://*.googlevideo.com/*",
    "https://*.cloudflarestream.com/*",
    "https://*.akamaized.net/*",
    "https://*.cloudfront.net/*",
    "https://*.amazonaws.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.skool.com/*",
        "https://*.loom.com/*",
        "https://*.vimeo.com/*",
        "https://*.wistia.com/*",
        "https://*.youtube.com/*"
      ],
      "js": ["inject-main.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Skool Video Capture",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}